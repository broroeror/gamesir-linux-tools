# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS / editor cruft
.DS_Store
*.swp
*~

# Large reverse-engineering captures (kept locally; excluded from the lean
# baseline so the repo stays small. Track with git-lfs if you want them in git.)
USBPcap Controller Tests/
*.pcapng
*.pcap

# Local RE/testing scratch area: vendor Windows apps (GameSir Connect / Nexus),
# their bundled .ufw firmware packages, raw flash dumps, and per-controller
# captures/screenshots. ALL third-party/proprietary or device-specific - never
# commit. Kept locally only.
Controller Testing/
*.ufw

# Local backups exported by the app
gamesir_backup_*.json

# Asset / reference packs (downloaded icon packs, UI reference screenshots) -
# not needed to run the app; kept locally but out of the lean baseline.
Icons and Images/
*.zip


# Firmware library — your own controller's firmware backups. NEVER committed
# (GameSir firmware is not redistributed; you create these locally via Backup).
firmware/

# jl-uboot-tool (kagaimiq, MIT) — the external loader read/write tool that the
# optional firmware Backup & Restore feature needs. NOT bundled/redistributed:
# install it here yourself (see FIRMWARE.md). Ignored so it's never committed.
jl-uboot-tool/

# Superseded/experimental code kept locally for reference, out of the published
# repo. Nothing here is imported by the app; history for anything moved here is
# still in git (git log --follow / git show <sha>:<path>).
attic/
